{
  "name": "stecute",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:network": "vite --host 0.0.0.0",
    "dev:https": "node scripts/dev-https.mjs",
    "build": "npm run seo:assets && vue-tsc -b --noEmit && vite build && npm run seo:pages",
    "preview": "vite preview",
    "seo:assets": "node scripts/generate-seo-assets.mjs",
    "seo:pages": "node scripts/write-seo-pages.mjs",
    "pwa:audit": "node scripts/audit-pwa.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "lint": "eslint . --ext .vue,.js,.jsx,.ts,.tsx",
    "format": "prettier --write \"src/**/*.{ts,tsx,vue,css,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,vue,css,json}\"",
    "typecheck": "vue-tsc --noEmit"
  },
  "dependencies": {
    "@mediapipe/tasks-vision": "^0.10.35",
    "dexie": "^4.0.11",
    "pinia": "^3.0.3",
    "vue": "^3.5.30",
    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@playwright/test": "^1.55.0",
    "@tailwindcss/vite": "^4.1.8",
    "@types/node": "^25.5.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/tsconfig": "^0.9.0",
    "eslint": "^9.28.0",
    "eslint-plugin-vue": "^10.4.0",
    "prettier": "^3.5.3",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "tailwindcss": "^4.1.8",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.34.1",
    "vite": "^7.3.2",
    "vite-plugin-pwa": "^1.0.2",
    "vitest": "^3.2.4",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.2.5"
  },
  "overrides": {
    "serialize-javascript": "^7.0.5"
  }
}
